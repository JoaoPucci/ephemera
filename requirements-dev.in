# Source of truth for dev-time dependencies (contributor machines + CI).
# Edit this file, NOT requirements-dev.txt.
#
# `-r requirements.in` pulls in every runtime dep so one install covers both.
#
# Regenerate the hashed requirements-dev.txt after editing:
#     ./venv/bin/pip-compile --allow-unsafe --generate-hashes --resolver=backtracking requirements-dev.in
#
# (See requirements.in for the explanation of --allow-unsafe; same
# rationale applies here.)

-r requirements.in

pytest>=8.0
pytest-cov>=6.0
# hypothesis powers property-based tests in tests/test_crypto.py and
# tests/test_validation.py -- the framework generates random inputs to
# exercise an invariant ("for any X, P holds") rather than asserting
# against a hand-picked example. Catches edge cases that human/AI-
# written example tests miss, particularly on cryptographic round-
# trips and size-cap boundaries.
hypothesis>=6.100
# radon is the cyclomatic-complexity meter used by
# scripts/crap_report.py in CI. Pinned only as a floor; the report is
# informational and a minor bump won't change rank order in practice.
radon>=6.0
# cosmic-ray is the mutation-testing engine used by the weekly
# .github/workflows/mutation-test.yml job. Mutates the codebase and
# re-runs the test suite to find places where tests don't actually
# fail when the code is broken (test theatre). Slow per-run -- run
# scheduled, not per-PR. Pinned floor only; the report is
# informational and minor cosmic-ray bumps don't change the contract.
#
# Migrated from mutmut after a hard interaction between mutmut's
# stats-phase pytest invocation and cryptography's PyO3 Rust
# bindings -- mutmut's reuse of a single Python process across all
# mutants caused a class-identity check inside cryptography's HKDF
# binding to fail. Cosmic-ray's session/job model spawns a fresh
# subprocess per mutant, so cryptography re-initialises cleanly each
# time. Confirmed via local spike: 96/106 mutants killed on
# crypto.py in 90 seconds; 71/85 on validation.py.
cosmic-ray>=8.4
httpx>=0.27
pip-tools>=7.4
