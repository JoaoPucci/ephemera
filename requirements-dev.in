pytest-cov>=6.0
# hypothesis powers property-based tests in tests/test_crypto.py and
# tests/test_validation.py -- the framework generates random inputs to
# exercise an invariant ("for any X, P holds") rather than asserting
# against a hand-picked example. Catches edge cases that human/AI-
# written example tests miss, particularly on cryptographic round-
# trips and size-cap boundaries.
hypothesis>=6.100
