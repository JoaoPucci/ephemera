.vscode/
.idea/
.DS_Store
Thumbs.db

# Private runbook (local only)
DEPLOYMENT.md

# Local-only review notes and draft docs. Folder-level rule so anything
# dropped in here stays local by default.
audit/

# Logs
*.log

# Coverage
.coverage
.coverage.*
coverage.xml
htmlcov/

# Node (Vitest + Playwright)
node_modules/
coverage/
playwright-report/
test-results/
/playwright/.cache/

# Claude Code state. Mixed: some subdirs are shareable team config that
# encodes how Claude works on this codebase (agents, skills, commands)
# and should travel with the repo; the rest is per-checkout / per-session
# (memory caches, lockfiles, local settings) and must never be committed.
# Default-deny: explicit allowlist for the shareable subdirs only, so
# any new private path Claude Code adds in the future stays blocked
# unless we opt into it.
.claude/*
!.claude/agents/
!.claude/skills/
!.claude/commands/
