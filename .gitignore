# Python
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.ruff_cache/
.mypy_cache/

# Virtual environment
venv/
.venv/
env/

# Local secrets & data
.env
*.db
*.db-journal
*.db-wal
*.db-shm

# Editor / OS
.vscode/
.idea/
.DS_Store
Thumbs.db

# Private runbook (local only)
DEPLOYMENT.md

# Local-only review notes and draft docs. Folder-level rule so anything
# dropped in here stays local by default.
audit/

# Logs
*.log

# Coverage
.coverage
.coverage.*
coverage.xml
coverage.json
htmlcov/

# Cosmic-ray. SQLite session files produced by `cosmic-ray init` (one
# per mutation run, named whatever the workflow / local invocation
# passes as the second argument). The CI workflow uses the bare
# `session.sqlite`; local invocations may pick anything. Cover the
# common shapes -- `session.sqlite` (workflow + the cosmic-ray docs'
# default), and the longer-form variants developers tend to use.
# Generated artifact; never committed.
session.sqlite
*.cosmic-ray.sqlite
cosmic-ray-session*.sqlite

# Node (Vitest + Playwright)
node_modules/
coverage/
playwright-report/
test-results/
/playwright/.cache/

# Claude Code state. Mixed: some subdirs are shareable team config that
# encodes how Claude works on this codebase (agents, skills, commands)
# and should travel with the repo; the rest is per-checkout / per-session
# (memory caches, lockfiles, local settings) and must never be committed.
# Default-deny: explicit allowlist for the shareable subdirs only, so
# any new private path Claude Code adds in the future stays blocked
# unless we opt into it.
.claude/*
!.claude/agents/
!.claude/skills/
!.claude/commands/
