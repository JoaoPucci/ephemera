EPHEMERA_SECRET_KEY=change-me-to-a-long-random-string
EPHEMERA_DB_PATH=./ephemera.db
# Use whichever host you open in the browser; dev server binds 127.0.0.1.
EPHEMERA_BASE_URL=http://127.0.0.1:8000
EPHEMERA_MAX_IMAGE_BYTES=10485760
# Both are listed because browsers treat them as different origins.
EPHEMERA_ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000
