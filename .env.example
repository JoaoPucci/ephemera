# Dev config is preferred at ~/.local/share/ephemera-dev/.env so secrets
# don't sit next to code (tar/rsync/IDE-search/backup hygiene). A .env at
# the repo root is still read for backward compat -- the XDG one just
# takes precedence if both exist.
EPHEMERA_SECRET_KEY=change-me-to-a-long-random-string
# Point this at wherever your dev DB lives. Same hygiene note as above --
# prefer keeping dev state out of the repo tree so backup / rsync / IDE-
# search tooling pointed at the project folder doesn't pick up secrets
# along with code. Expand the ~ yourself in your real .env (this template
# intentionally uses a literal path so nothing's ambiguous).
EPHEMERA_DB_PATH=/home/<you>/.local/share/ephemera-dev/ephemera.db
# Use whichever host you open in the browser; dev server binds 127.0.0.1.
EPHEMERA_BASE_URL=http://127.0.0.1:8000
EPHEMERA_MAX_IMAGE_BYTES=10485760
# Both are listed because browsers treat them as different origins.
EPHEMERA_ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000
# Label shown next to accounts in TOTP authenticator apps. Pick a different
# value per environment ("ephemera-dev", "ephemera-prod") so entries from
# multiple instances don't visually collide in your authenticator.
# EPHEMERA_TOTP_ISSUER=ephemera
# Session cookies get the Secure flag by default. Loopback (127.0.0.1,
# localhost) is a secure context in modern browsers, so dev is fine.
# Override only if a legacy browser or a non-standard TLS path forces it.
# EPHEMERA_SESSION_COOKIE_SECURE=true
# Session cookie name. Override only if you're running multiple ephemera
# instances on the same domain and want distinct cookie scopes.
# EPHEMERA_SESSION_COOKIE_NAME=ephemera_session
# Session lifetime in seconds (default 8 hours). Lower for a stricter
# sign-in window, higher for a more permissive one.
# EPHEMERA_SESSION_MAX_AGE=28800
# Reveal-passphrase attempt limit before the secret is destroyed (default 5).
# EPHEMERA_MAX_PASSPHRASE_ATTEMPTS=5
# How often the cleanup loop sweeps expired secrets, in seconds (default 60).
# Lower for snappier cleanup, higher for less DB churn.
# EPHEMERA_CLEANUP_INTERVAL_SECONDS=60
# How long viewed/expired tracked secrets stay listed before they're pruned,
# in seconds (default 30 days).
# EPHEMERA_TRACKED_RETENTION_SECONDS=2592000
# Aggregate-only product analytics (presence-only events, no user identity,
# no payload content). Off by default -- a privacy-focused tool shouldn't
# collect telemetry without explicit operator consent. Flip to true to opt in.
# EPHEMERA_ANALYTICS_ENABLED=false
