# Dev config is preferred at ~/.local/share/ephemera-dev/.env so secrets
# don't sit next to code (tar/rsync/IDE-search/backup hygiene). A .env at
# the repo root is still read for backward compat -- the XDG one just
# takes precedence if both exist.
EPHEMERA_SECRET_KEY=change-me-to-a-long-random-string
# Point this at wherever your dev DB lives. Same hygiene note as above --
# prefer ~/.local/share/ephemera-dev/ephemera.db over the repo root.
EPHEMERA_DB_PATH=./ephemera.db
# Use whichever host you open in the browser; dev server binds 127.0.0.1.
EPHEMERA_BASE_URL=http://127.0.0.1:8000
EPHEMERA_MAX_IMAGE_BYTES=10485760
# Both are listed because browsers treat them as different origins.
EPHEMERA_ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000
# Label shown next to accounts in TOTP authenticator apps. Pick a different
# value per environment ("ephemera-dev", "ephemera-prod") so entries from
# multiple instances don't visually collide in your authenticator.
# EPHEMERA_TOTP_ISSUER=ephemera
# Session cookies get the Secure flag by default. Loopback (127.0.0.1,
# localhost) is a secure context in modern browsers, so dev is fine.
# Override only if a legacy browser or a non-standard TLS path forces it.
# EPHEMERA_SESSION_COOKIE_SECURE=true
